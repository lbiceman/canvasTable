{
  "enabled": true,
  "name": "Claude Code 完成通知",
  "description": "当 .demand/ 目录下创建新的 md 文件时，自动读取 .handoff/ 目录下的最新文件，了解 Claude Code 完成的内容并继续执行下一步任务",
  "version": "1",
  "when": {
    "type": "fileCreated",
    "patterns": [
      ".demand/*.md"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Claude Code 已完成任务，请读取 .handoff/ 目录下最新的文件，了解完成内容和上下文，然后继续执行下一步任务。"
  }
}