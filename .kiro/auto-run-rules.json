{
  "version": "1.0",
  "description": "任务完成后自动执行规则的配置文件",
  "rules": [
    {
      "id": "spec-task-completed",
      "name": "Spec 任务完成后自动执行",
      "trigger": "当 .kiro/specs/<feature>/tasks.md 中所有非可选任务都完成时触发",
      "enabled": true,
      "actions": [
        {
          "type": "check-tasks",
          "description": "检查 tasks.md 是否有未完成的任务（忽略带 * 的可选任务）",
          "continueIf": "所有任务都完成"
        },
        {
          "type": "run-e2e-test",
          "description": "运行 Playwright e2e 测试",
          "testFile": "e2e/<spec-name>.spec.ts",
          "updateSnapshot": true,
          "continueIf": "测试通过"
        },
        {
          "type": "fix-and-retry",
          "description": "如果测试失败，修复源代码后重试（最多 3 次）",
          "maxRetries": 3
        },
        {
          "type": "git-commit",
          "description": "所有测试通过后自动提交代码",
          "commitMessage": "feat: 完成 <spec-name> 功能",
          "push": true
        }
      ]
    }
  ],
  "settings": {
    "specsToWatch": ["cell-vertical-align", "horizontal-align-button-group", "collaborative-editing", "node-to-java-migration"],
    "excludeOptionalTasks": true
  },
  "howToUse": "当你在 spec 的 tasks.md 中标记任务完成后（有 [x] 标记），我会自动检查并执行上述操作。你可以直接修改此配置来调整行为。"
}
